# -----------------------------------------------------------------------------
# Docker Compose Environment Template
# -----------------------------------------------------------------------------
# Copy to .env.docker and set values for your environment.
#
# Usage:
#   cp .env.docker.example .env.docker
#   docker-compose --env-file .env.docker up
# -----------------------------------------------------------------------------

# REQUIRED - App
NODE_ENV=development
PORT=3000

# REQUIRED - Postgres container/bootstrap values
POSTGRES_USER=backend_user
POSTGRES_PASSWORD=backend_password
POSTGRES_DB=backend_dev

# REQUIRED - JWT validation boundary
JWT_ISSUER=https://issuer.example.com
JWT_AUDIENCE=backend-api
JWT_ALGORITHM=RS256

# REQUIRED IF JWT_ALGORITHM=HS256
# JWT_SECRET=replace-with-secret

# REQUIRED IF JWT_ALGORITHM=RS256 OR ES256 (set one)
JWT_PUBLIC_KEY=
JWT_JWKS_URI=

# OPTIONAL - Admin console
ADMIN_CONSOLE_ENABLED=false
ADMIN_USER_IDS=

# OPTIONAL - Scenario testing
# Keep false by default. Production mode rejects SCENARIO_TESTING=true.
SCENARIO_TESTING=false

# OPTIONAL - In-app scheduler
IN_APP_SCHEDULER_ENABLED=false
SCHEDULER_MODE=cron
SCHEDULER_DAILY_CRON=0 3 * * *
SCHEDULER_TIMEZONE=UTC