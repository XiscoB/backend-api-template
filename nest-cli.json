{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "modules/internal-admin/view/**/*",
        "outDir": "dist",
        "watchAssets": true
      },
      {
        "include": "infrastructure/email/templates/locales/**/*.json",
        "outDir": "dist",
        "watchAssets": true
      },
      {
        "include": "infrastructure/email/templates/**/*.html",
        "outDir": "dist",
        "watchAssets": true
      }
    ]
  }
}
