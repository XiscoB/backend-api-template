{
  "name": "backend-base-api",
  "version": "0.1.0",
  "description": "Reusable Backend API Template - Production-grade NestJS backend baseline",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ]
  },
  "scripts": {
    "build": "npm run generate:admin && nest build",
    "generate:admin": "ts-node scripts/ci/generate-admin-tables.ts",
    "check:admin-visibility": "ts-node scripts/ci/check-admin-visibility.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:migrate": "prisma migrate deploy && node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate && prisma format --check",
    "prisma:format": "prisma format",
    "db:test-connection": "node scripts/dev/test-db-connection.js",
    "db:validate": "ts-node scripts/ci/validate-db.ts",
    "db:verify": "npm run prisma:validate && npm run db:validate",
    "validate:all": "ts-node scripts/ci/validate-all.ts",
    "postinstall": "prisma generate",
    "docker:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/ci/sync-docker-env.ps1",
    "docker:up": "npm run docker:sync && docker-compose up --build",
    "docker:up:detach": "npm run docker:sync && docker-compose up --build -d && npm run prisma:migrate:deploy",
    "docker:down": "docker-compose down",
    "docker:reset:WARNINGDELETEALL": "docker-compose down -v && npm run docker:sync && docker-compose up --build -d && timeout /t 5 && npm run prisma:migrate:deploy && docker-compose logs -f",
    "docker:logs": "docker logs backend-base-api --tail 50",
    "docker:restart": "docker restart backend-base-api",
    "job:notifications": "ts-node scripts/ops/jobs/run-notifications.ts",
    "job:reports-digest": "ts-node scripts/ops/jobs/run-reports-digest.ts",
    "job:retries": "ts-node scripts/ops/jobs/run-retries.ts",
    "job:cleanup": "ts-node scripts/ops/jobs/run-cleanup.ts",
    "job:gdpr": "ts-node scripts/ops/jobs/run-gdpr.ts",
    "job:all": "ts-node scripts/ops/jobs/run-all.ts",
    "test:gdpr": "node scripts/dev/test-gdpr.js",
    "test:scenarios": "node scripts/dev/scenarios/run-scenarios.js",
    "test:system": "pwsh -ExecutionPolicy Bypass -File ./test/system/run-lifecycle-test.ps1",
    "lint:changed": "eslint src/modules/gdpr src/modules/bootstrap",
    "lint:scripts:critical": "eslint scripts/ci scripts/ops",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.962.0",
    "@aws-sdk/s3-request-presigner": "^3.962.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "archiver": "^7.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "joi": "^17.13.0",
    "jwks-rsa": "^3.1.0",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/archiver": "^7.0.0",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "axios": "^1.13.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.3.0",
    "prisma": "^7.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
