# -----------------------------------------------------------------------------
# Backend Base API - Environment Template
# -----------------------------------------------------------------------------
# No secrets in this file. Replace placeholder values in your local .env.
#
# Fail-fast JWT contract:
# - HS256: requires JWT_SECRET
# - RS256/ES256: requires JWT_PUBLIC_KEY or JWT_JWKS_URI
# - No silent fallback between symmetric/asymmetric modes
# -----------------------------------------------------------------------------

# REQUIRED
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/backend_dev?schema=public
JWT_ISSUER=https://issuer.example.com
JWT_AUDIENCE=backend-api
JWT_ALGORITHM=RS256

# REQUIRED IF JWT_ALGORITHM=HS256
# JWT_SECRET=replace-with-secret

# REQUIRED IF JWT_ALGORITHM=RS256 OR ES256 (set one)
JWT_PUBLIC_KEY=
JWT_JWKS_URI=

# OPTIONAL - Application
PORT=3000

# OPTIONAL - Admin console (disabled by default)
ADMIN_CONSOLE_ENABLED=false
ADMIN_USER_IDS=

# OPTIONAL - Scenario testing (CI/local tests only, never production)
SCENARIO_TESTING=false

# OPTIONAL - In-app scheduler
IN_APP_SCHEDULER_ENABLED=false
SCHEDULER_MODE=cron
SCHEDULER_EVERY_MINUTE_CRON=* * * * *
SCHEDULER_DAILY_CRON=0 3 * * *
SCHEDULER_TIMEZONE=UTC

# OPTIONAL - Rate limiting backend
RATE_LIMIT_DRIVER=memory
REDIS_URL=
RATE_LIMIT_FALLBACK_ENABLED=true
RATE_LIMIT_FALLBACK_MEMORY_TTL_SECONDS=60
RATE_LIMIT_FALLBACK_MEMORY_MAX_ENTRIES=10000
RATE_LIMIT_FALLBACK_PROBE_COOLDOWN_MS=30000
RATE_LIMIT_FALLBACK_CLEANUP_INTERVAL_MS=60000

# OPTIONAL - Email delivery
EMAIL_PROVIDER=console
EMAIL_ENABLED=true
EMAIL_DEFAULT_FROM=noreply@example.com
EMAIL_DEFAULT_FROM_NAME=Backend Template
SPARKPOST_API_KEY=
SPARKPOST_API_ENDPOINT=https://api.sparkpost.com/api/v1
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

# OPTIONAL - GDPR export storage
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GDPR_EXPORT_TTL_DAYS=7
GDPR_PRESIGNED_URL_TTL_SECONDS=300