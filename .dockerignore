# ─────────────────────────────────────────────────────────────────
# Docker Ignore
# ─────────────────────────────────────────────────────────────────
# Files and directories to exclude from Docker build context.

# Dependencies (will be installed in container)
node_modules

# Build output
dist

# Environment files (sensitive)
.env
.env.*
!.env.example
!.env.docker.example

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Documentation
*.md
!README.md
docs

# Test files
test
coverage
*.spec.ts
*.e2e-spec.ts
jest*.json

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker files (no need to copy into image)
Dockerfile
docker-compose*.yml
.dockerignore
