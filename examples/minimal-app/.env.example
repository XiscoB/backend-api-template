# ============================================================================
# Minimal Example App - Environment Configuration
# ============================================================================
# This file documents environment variables required to boot the backend.
# Copy to .env and fill in values appropriate for your identity provider.
#
# No secrets. No provider-specific values. No real URLs.
# ============================================================================

# ----------------------------------------------------------------------------
# JWT Validation - Issuer & Audience
# ----------------------------------------------------------------------------

# Expected 'iss' claim value in JWT tokens.
# Must match the issuer URL of your identity provider.
JWT_ISSUER=https://your-idp.example.com

# Expected 'aud' claim value in JWT tokens.
# Tokens must include this audience to be accepted.
JWT_AUDIENCE=your-audience

# ----------------------------------------------------------------------------
# JWT Validation - Key Configuration
# ----------------------------------------------------------------------------
# Provide ONE of: JWT_SECRET, JWT_PUBLIC_KEY, or JWT_JWKS_URI.
# Algorithm is inferred from which variable is set.
# ----------------------------------------------------------------------------

# Symmetric secret for HS256 validation.
# Use this when your identity provider signs tokens with a shared secret.
# JWT_SECRET=your-symmetric-secret-here

# Static RSA public key for RS256 validation.
# Use this when you have a fixed public key from your identity provider.
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBI...\n-----END PUBLIC KEY-----

# JWKS endpoint for RS256 validation with key rotation.
# Commonly used in production environments - supports automatic key rotation.
# JWT_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json

# ----------------------------------------------------------------------------
# Database Connection
# ----------------------------------------------------------------------------

# PostgreSQL connection string.
# Required for identity persistence.
DATABASE_URL=postgresql://user:password@localhost:5432/database

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# - Only one key configuration variable should be set at a time.
# - If multiple are set, validation will fail with a configuration error.
# - See the main project .env.example for additional options.
# ============================================================================
